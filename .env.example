# Google Calendar連携を使う場合に必要です。
# Google Cloud Consoleで作成した OAuth 2.0 Client ID を設定してください。
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# 任意です。設定した時だけ、Settingsに「お問い合わせフォーム」リンクが表示されます。
# 改善点、不具合、使ってみた感想、連絡したいことを受け取れるURLを入れてください。
VITE_CONTACT_URL=

# 旧名です。既存のVercel環境向けfallbackとして読みます。
# 新しく設定する場合は VITE_CONTACT_URL を使ってください。
VITE_FEEDBACK_URL=

# 実際の値は .env.local に入れ、GitHubへコミットしません。
# Google Cloud Console の Authorized JavaScript origins には、
# ローカル確認用の http://localhost:5173 と Vercel本番の origin を登録してください。
